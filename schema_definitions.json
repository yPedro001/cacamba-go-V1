        "type": "string"
      },
      "cacamba_id": {
        "description": "Note:\nThis is a Foreign Key to `cacambas.id`.<fk table='cacambas' column='id'/>",
        "format": "uuid",
        "type": "string"
      },
      "endereco_obra": {
        "format": "text",
        "type": "string"
      },
      "valor": {
        "format": "numeric",
