{
  "cacambas": {
    "required": [
      "id",
      "identificador",
      "status"
    ],
    "properties": {
      "id": {
        "default": "extensions.uuid_generate_v4()",
        "description": "Note:\nThis is a Primary Key.<pk/>",
        "format": "uuid",
        "type": "string"
      },
      "identificador": {
        "format": "text",
        "type": "string"
      },
      "status": {
        "default": "disponivel",
        "format": "text",
        "type": "string"
      },
      "created_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      },
      "codigo": {
        "format": "text",
        "type": "string"
      }
    },
    "type": "object"
  },
  "alugueis": {
