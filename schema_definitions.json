      },
      "created_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      },
      "quantidade_cacambas": {
        "default": 1,
        "format": "integer",
        "type": "integer"
      },
      "valor_bruto": {
        "format": "numeric",
        "type": "number"
      },
      "taxa_cartao_percent": {
        "format": "numeric",
        "type": "number"
      },
      "juros_parcelas_percent": {
        "format": "numeric",
        "type": "number"
      },
      "valor_taxa": {
        "format": "numeric",
        "type": "number"
      },
      "valor_liquido": {
        "format": "numeric",
        "type": "number"
      },
      "pago": {
        "default": false,
        "format": "boolean",
        "type": "boolean"
      },
      "valor_pago": {
        "format": "numeric",
        "type": "number"
      },
      "latitude": {
        "format": "numeric",
        "type": "number"
      },
      "longitude": {
        "format": "numeric",
        "type": "number"
      },
      "local_endereco": {
        "format": "text",
        "type": "string"
      },
      "data_inicio": {
        "format": "timestamp with time zone",
        "type": "string"
      },
      "data_fim_prevista": {
        "format": "timestamp with time zone",
        "type": "string"
      }
    },
    "type": "object"
  },
  "profiles": {
    "required": [
      "id",
      "email",
      "role",
      "status"
    ],
    "properties": {
      "id": {
        "description": "Note:\nThis is a Primary Key.<pk/>",
        "format": "uuid",
        "type": "string"
      },
      "full_name": {
        "format": "text",
        "type": "string"
      },
      "email": {
        "format": "text",
        "type": "string"
      },
      "role": {
        "default": "user",
        "enum": [
          "user",
          "admin"
        ],
        "format": "public.user_role",
        "type": "string"
      },
      "status": {
        "default": "active",
        "enum": [
          "active",
          "suspended",
          "deleted"
        ],
        "format": "public.account_status",
        "type": "string"
      },
      "access_count": {
        "default": 0,
        "format": "integer",
        "type": "integer"
      },
      "last_login_at": {
        "format": "timestamp with time zone",
        "type": "string"
      },
      "updated_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      },
      "created_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      },
      "cor_primaria": {
        "default": "#ff6b00",
        "format": "character varying",
        "maxLength": 7,
        "type": "string"
      },
      "chave_pix": {
        "format": "text",
        "type": "string"
      },
      "sync_status": {
        "default": "synced",
        "format": "text",
        "type": "string"
      },
      "last_access_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      }
    },
    "type": "object"
  },
